# LLM Configuration
# 使用中间代理访问 LLM
LLM_API_BASE=https://your-llm-proxy.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-6-20250929

# Storage Configuration
DATA_DIR=D:/GitHub_simulation/data
MAX_STORAGE_GB=5

# SQLite Configuration
DATABASE_URL=sqlite:///D:/GitHub_simulation/data/db/github_sim.db

# ChromaDB Configuration
CHROMA_PERSIST_DIR=D:/GitHub_simulation/data/vectors/chroma

# Simulation Configuration
DEFAULT_AGENT_COUNT=5
MAX_AGENT_COUNT=50

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# GitHub API (optional, for data fetching)
GITHUB_TOKEN=

# Retry Configuration
MAX_RETRIES=3
RETRY_BACKOFF=2
